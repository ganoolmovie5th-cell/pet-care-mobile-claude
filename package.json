{
  "name": "pet-care-mobile",
  "version": "0.1.0",
  "description": "Pet Care Community MVP - React Native mobile app",
  "main": "expo-app.json",
  "scripts": {
    "web": "expo start --web",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/",
